FLASK_APP=app:create_app
FLASK_DEBUG=0
SECRET_KEY=change-me
# Template: mysql+pymysql://username:password@host:port/dbname
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/dublinbikes

# JCDecaux Public Bike API
JCDECAUX_API_KEY=your_jcdecaux_api_key_here
JCDECAUX_CONTRACT=dublin
JCDECAUX_BASE_URL=https://api.jcdecaux.com/vls/v1/stations
SCRAPE_INTERVAL_SECONDS=300
RETRY_INTERVAL_SECONDS=60
OUTPUT_JSON=stations.json

# JWT (required)
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_REFRESH_SECRET_KEY=your_jwt_refresh_secret_key_here

# Flask-Mail / SMTP (send verification code emails; leave blank to output to console only)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_USE_TLS=true
# MAIL_DEFAULT_FROM_NAME=

# Frontend activation link base URL (the "click to activate" link in emails)
FRONTEND_BASE_URL=http://localhost:5173

# OpenWeatherMap API (for weather forecasts)
OPENWEATHER_API_BASE_URL=https://api.openweathermap.org/data/3.0/onecall
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Google Maps API (for route planning)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Aliyun Qwen (for chat)
ALIYUN_API_KEY=your_aliyun_api_key_here
