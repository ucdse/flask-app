FLASK_APP=app:create_app
FLASK_DEBUG=0
SECRET_KEY=change-me
# 模板：mysql+pymysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/dublinbikes

# JWT（必填）
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_REFRESH_SECRET_KEY=your_jwt_refresh_secret_key_here

# Flask-Mail / SMTP（发验证码邮件；不填则仅控制台输出）
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_USE_TLS=true
# MAIL_DEFAULT_FROM_NAME=

# 前端激活链接基础 URL（邮件里的「点击激活」链接）
FRONTEND_BASE_URL=http://localhost:5173

# OpenWeatherMap API（用于天气预报）
OPENWEATHER_API_BASE_URL=https://api.openweathermap.org/data/3.0/onecall
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Google Maps API（用于路径规划）
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# 阿里云 Qwen（用于聊天）
ALIYUN_API_KEY=your_aliyun_api_key_here
